# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# These are exposed to the browser via Vite's import.meta.env.
# They are safe to expose because they are the Supabase *anon* key, not the
# service-role key. Access is controlled by Row Level Security (RLS) in the DB.
#
# Copy this file to .env.local and fill in your real values.
# .env.local is git-ignored and must never be committed.
#
# For Netlify deployment: add these as environment variables in the Netlify
# dashboard under Site → Environment variables.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Netlify Function (server-side only) ──────────────────────────────────────
# This key is read only inside netlify/functions/confirm-booking.ts.
# It is NEVER included in the browser bundle and NEVER in VITE_ prefixed vars.
#
# For local development with `netlify dev`: add to .env.local.
# For Netlify deployment: add in the Netlify dashboard under Environment variables.

ANTHROPIC_API_KEY=sk-ant-your-key-here
